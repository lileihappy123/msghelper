{
  "info": {
    "_postman_id": "msghelper-openapi-quota-test-v2",
    "name": "MsgHelper OpenAPI Quota Test (Client Credentials)",
    "description": "用于验证 client_credentials 调用 Python OpenAPI 以及配额扣减/批量回传行为（3次或8秒）",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1) Python登录封装（client_credentials）",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tenantId\": \"{{TENANT_ID}}\",\n  \"clientId\": \"{{CLIENT_ID}}\",\n  \"clientSecret\": \"{{CLIENT_SECRET}}\",\n  \"loginMode\": \"client_credentials\",\n  \"scope\": \"msghelper.api\",\n  \"forceRelogin\": false\n}"
        },
        "url": {
          "raw": "{{PY_BASE_URL}}/api/auth/login",
          "host": ["{{PY_BASE_URL}}"],
          "path": ["api", "auth", "login"]
        },
        "description": "获取并缓存 accessToken。"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let j = {};",
              "try { j = pm.response.json(); } catch (e) {}",
              "const d = j?.data?.data || {};",
              "const token = d?.accessToken || d?.access_token || '';",
              "const refresh = d?.refreshToken || d?.refresh_token || '';",
              "if (token) pm.collectionVariables.set('ACCESS_TOKEN', token);",
              "if (refresh) pm.collectionVariables.set('REFRESH_TOKEN', refresh);",
              "pm.test('登录成功并拿到 token', function () {",
              "  pm.expect(token).to.not.eql('');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2) 获取客户端版本 /api/get_version（不计套餐配额）",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" },
          { "key": "tenant-id", "value": "{{TENANT_ID}}" },
          { "key": "user-id", "value": "0" }
        ],
        "url": {
          "raw": "{{PY_BASE_URL}}/api/get_version",
          "host": ["{{PY_BASE_URL}}"],
          "path": ["api", "get_version"]
        }
      }
    },
    {
      "name": "3) 获取已打开微信版本 /api/get_opened_wx_version（会触发配额）",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" },
          { "key": "tenant-id", "value": "{{TENANT_ID}}" },
          { "key": "user-id", "value": "0" }
        ],
        "url": {
          "raw": "{{PY_BASE_URL}}/api/get_opened_wx_version",
          "host": ["{{PY_BASE_URL}}"],
          "path": ["api", "get_opened_wx_version"]
        },
        "description": "即使接口业务报错（如找不到微信窗口），只要经过 /api 拦截器，也可能累计/回传配额。"
      }
    },
    {
      "name": "4) 再调一次 /api/get_opened_wx_version",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" },
          { "key": "tenant-id", "value": "{{TENANT_ID}}" },
          { "key": "user-id", "value": "0" }
        ],
        "url": {
          "raw": "{{PY_BASE_URL}}/api/get_opened_wx_version",
          "host": ["{{PY_BASE_URL}}"],
          "path": ["api", "get_opened_wx_version"]
        }
      }
    },
    {
      "name": "5) 第三次快速调用 /api/get_opened_wx_version（建议8秒内完成）",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" },
          { "key": "tenant-id", "value": "{{TENANT_ID}}" },
          { "key": "user-id", "value": "0" }
        ],
        "url": {
          "raw": "{{PY_BASE_URL}}/api/get_opened_wx_version",
          "host": ["{{PY_BASE_URL}}"],
          "path": ["api", "get_opened_wx_version"]
        },
        "description": "默认批量回传阈值=3。若 pending=0，通常会新增一条 consumed=3 的明细。"
      }
    },
    {
      "name": "6) 查询本地开放API余额 /api/openapi-quota/balance",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" },
          { "key": "tenant-id", "value": "{{TENANT_ID}}" },
          { "key": "user-id", "value": "0" }
        ],
        "url": {
          "raw": "{{PY_BASE_URL}}/api/openapi-quota/balance?tenantId={{TENANT_ID}}",
          "host": ["{{PY_BASE_URL}}"],
          "path": ["api", "openapi-quota", "balance"],
          "query": [
            { "key": "tenantId", "value": "{{TENANT_ID}}" }
          ]
        }
      }
    },
    {
      "name": "7) 后端余额接口（可选，需管理端token）",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" },
          { "key": "tenant-id", "value": "1" }
        ],
        "url": {
          "raw": "{{BACKEND_BASE_URL}}/system/msghelper-api-quota/balance?tenantId={{TENANT_ID}}",
          "host": ["{{BACKEND_BASE_URL}}"],
          "path": ["system", "msghelper-api-quota", "balance"],
          "query": [
            { "key": "tenantId", "value": "{{TENANT_ID}}" }
          ]
        }
      }
    },
    {
      "name": "8) 后端余额接口（OAuth2 client token）",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" },
          { "key": "tenant-id", "value": "{{TENANT_ID}}" }
        ],
        "url": {
          "raw": "{{BACKEND_BASE_URL}}/system/msghelper-api-quota/balance?tenantId={{TENANT_ID}}",
          "host": ["{{BACKEND_BASE_URL}}"],
          "path": ["system", "msghelper-api-quota", "balance"],
          "query": [
            { "key": "tenantId", "value": "{{TENANT_ID}}" }
          ]
        },
        "description": "使用 client_credentials 模式获取的 ACCESS_TOKEN 直接请求后端余额接口。"
      }
    }
  ],
  "variable": [
    { "key": "PY_BASE_URL", "value": "http://127.0.0.1:6003", "type": "string" },
    { "key": "BACKEND_BASE_URL", "value": "http://127.0.0.1:48080/admin-api", "type": "string" },
    { "key": "TENANT_ID", "value": "154", "type": "string" },
    { "key": "CLIENT_ID", "value": "msghelper-client-154", "type": "string" },
    { "key": "CLIENT_SECRET", "value": "", "type": "string" },
    { "key": "ACCESS_TOKEN", "value": "", "type": "string" },
    { "key": "REFRESH_TOKEN", "value": "", "type": "string" },
    { "key": "ADMIN_TOKEN", "value": "", "type": "string" }
  ]
}
